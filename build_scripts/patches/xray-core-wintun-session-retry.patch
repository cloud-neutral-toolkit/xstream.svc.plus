+func startSessionWithRetry(adapter *wintun.Adapter, name string, capacity uint32) (wintun.Session, error) {
+	var zero wintun.Session
+	var lastErr error
+	for attempt := 0; attempt < wintunStartSessionRetries; attempt++ {
+		session, err := adapter.StartSession(capacity)
+		if err == nil {
+			return session, nil
+		}
+		if !errors.Is(err, windows.ERROR_ALREADY_INITIALIZED) {
+			return zero, err
+		}
+		lastErr = err
+		time.Sleep(wintunStartSessionDelay)
+	}
+	if lastErr == nil {
+		lastErr = windows.ERROR_ALREADY_INITIALIZED
+	}
+	return zero, fmt.Errorf("wintun adapter %q is already active in another xstream instance: %w", name, lastErr)
+}
